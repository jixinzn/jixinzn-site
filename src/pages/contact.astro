---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="联系我们" description="联系山西极芯智能科技有限公司。GEOAI搜索优化、AI智能体定制、AI数字人服务，免费获取企业AI曝光诊断。">
  <Header />
  <section class="page-hero">
    <div class="container">
      <span class="section-label">联系我们</span>
      <h1>一起开启AI获客新赛道</h1>
      <p>免费获取企业AI搜索曝光诊断，了解你的品牌在AI中的真实位置</p>
    </div>
  </section>
  <section class="contact-main">
    <div class="container contact-grid">
      <div class="contact-info">
        <h2>联系方式</h2>
        <div class="info-item">
          <span class="info-label">电话</span>
          <a href="tel:19036173963" class="info-value accent">19036173963</a>
        </div>
        <div class="info-item">
          <span class="info-label">邮箱</span>
          <a href="mailto:3238984729@qq.com" class="info-value">3238984729@qq.com</a>
        </div>
        <div class="info-item">
          <span class="info-label">地址</span>
          <span class="info-value">山西省太原市尖草坪区中北大街66号9幢四层A区033室</span>
        </div>
        <div class="info-item">
          <span class="info-label">服务时间</span>
          <span class="info-value">工作日 9:00 - 18:00</span>
        </div>
        <div class="divider"></div>
        <p class="response-note">收到您的咨询后，我们将在2小时内电话回复。</p>
      </div>
      <form class="contact-form card" netlify name="contact" method="POST">
        <input type="hidden" name="form-name" value="contact" />
        <h3>在线咨询</h3>
        <div class="form-group">
          <label>姓名 *</label>
          <input type="text" name="name" required />
        </div>
        <div class="form-group">
          <label>手机号 *</label>
          <input type="tel" name="phone" required />
        </div>
        <div class="form-group">
          <label>所属行业</label>
          <input type="text" name="industry" />
        </div>
        <div class="form-group">
          <label>需求描述</label>
          <textarea name="message" rows="4"></textarea>
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%">提交咨询</button>
      </form>
    </div>
  </section>
  <Footer />
</Layout>
<style>
  .contact-main { background: var(--bg-primary); }
  .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; }
  .contact-info h2 { font-size: 1.5rem; font-weight: 600; color: var(--text-primary); margin-bottom: 2rem; }
  .info-item { margin-bottom: 1.25rem; }
  .info-label { font-size: 0.75rem; font-weight: 600; color: var(--accent); letter-spacing: 0.05em; display: block; margin-bottom: 0.25rem; }
  .info-value { font-size: 0.95rem; color: var(--text-primary); display: block; }
  .info-value.accent { color: var(--accent); font-weight: 600; }
  .response-note { font-size: 0.85rem; color: var(--text-secondary); }
  .contact-form h3 { font-size: 1.15rem; font-weight: 600; color: var(--text-primary); margin-bottom: 1.5rem; }
  .form-group { margin-bottom: 1.25rem; }
  .form-group label { display: block; font-size: 0.85rem; font-weight: 500; color: var(--text-secondary); margin-bottom: 0.35rem; }
  .form-group input, .form-group textarea {
    width: 100%; padding: 0.75rem 1rem; border: 1px solid var(--border); border-radius: var(--radius);
    font-family: inherit; font-size: 0.9375rem; background: white; color: var(--text-primary);
  }
  .form-group input:focus, .form-group textarea:focus { outline: none; border-color: var(--accent); }
  @media (max-width: 768px) { .contact-grid { grid-template-columns: 1fr; gap: 2rem; } }
</style>
